;=======================================================================
; font.inc - Minimal 5x7 pixel bitmap font for VBE programs
;
; Characters: space (0x20), ! (0x21), digits 0-9 (0x30-0x39),
;             : (0x3A), - (0x2D), _ (0x5F set via alias),
;             uppercase A-Z (0x41-0x5A).
;
; API (all preserve all registers via pushad/popad):
;   vbe_draw_char   EBX=x  ECX=y  EDX=char(ASCII)  ESI=colour  EAX=scale
;   vbe_draw_str    EBX=x  ECX=y  EDX=ptr(NUL-term) ESI=colour  EAX=scale
;   vbe_draw_num    EBX=x  ECX=y  EDX=value(uint32) ESI=colour  EAX=scale
;   vbe_fill_circle EBX=cx ECX=cy EDX=r             ESI=colour
;
; Glyph format: 7 bytes per character.
;   Each byte = one row of 5 pixels (bits 4..0 = left..right).
; Font table indexed as: font_data + (char - FONT_FIRST) * 7
;=======================================================================

%ifndef FONT_INC
%define FONT_INC

%include "lib/vbe.inc"

FONT_FIRST  equ 0x20
FONT_LAST   equ 0x5F        ; includes '_' at 0x5F
FONT_W      equ 5
FONT_H      equ 7

;-----------------------------------------------------------------------
; vbe_draw_char - Draw one character
; Input:  EBX=x, ECX=y, EDX=char, ESI=colour, EAX=scale(>=1)
;-----------------------------------------------------------------------
vbe_draw_char:
        pushad
        ; bounds-check character
        cmp edx, FONT_FIRST
        jb  .vdc_done
        cmp edx, FONT_LAST
        ja  .vdc_done

        sub edx, FONT_FIRST
        imul edx, FONT_H            ; byte offset into font_data

        mov [.vdc_scale],  eax
        mov [.vdc_colour], esi
        mov [.vdc_x0],     ebx
        mov [.vdc_y0],     ecx

        xor ecx, ecx                ; row 0..6
.vdc_row:
        cmp ecx, FONT_H
        jge .vdc_done

        movzx eax, byte [font_data + edx + ecx]

        xor ebx, ebx                ; col 0..4
.vdc_col:
        cmp ebx, FONT_W
        jge .vdc_next_row

        ; test bit (4-col)
        mov edi, 4
        sub edi, ebx
        bt  eax, edi
        jnc .vdc_next_col

        ; compute pixel coords
        push eax
        push ebx
        push ecx

        mov eax, [.vdc_scale]
        push edx                    ; save font offset

        imul edx, ebx, 0            ; placeholder
        mov edx, ebx
        imul edx, [.vdc_scale]
        add edx, [.vdc_x0]          ; px_x

        mov esi, ecx
        imul esi, [.vdc_scale]
        add esi, [.vdc_y0]          ; px_y

        ; vbe_fill_rect(EBX=x, ECX=y, EDX=w, ESI=h, EDI=colour)
        mov  ebx, edx               ; x
        mov  ecx, esi               ; y
        mov  edx, [.vdc_scale]      ; w
        mov  esi, [.vdc_scale]      ; h
        mov  edi, [.vdc_colour]
        call vbe_fill_rect

        pop edx                     ; restore font offset
        pop ecx
        pop ebx
        pop eax

.vdc_next_col:
        inc ebx
        jmp .vdc_col

.vdc_next_row:
        inc ecx
        jmp .vdc_row

.vdc_done:
        popad
        ret

.vdc_scale:  dd 1
.vdc_colour: dd 0xFFFFFF
.vdc_x0:     dd 0
.vdc_y0:     dd 0

;-----------------------------------------------------------------------
; vbe_draw_str - Draw a NUL-terminated string
; Input:  EBX=x, ECX=y, EDX=ptr, ESI=colour, EAX=scale
;-----------------------------------------------------------------------
vbe_draw_str:
        pushad
        mov [.vds_ptr],    edx
        mov [.vds_scale],  eax
        mov [.vds_colour], esi
        mov [.vds_x],      ebx
        mov [.vds_y],      ecx

.vds_loop:
        mov  esi, [.vds_ptr]
        movzx edx, byte [esi]
        test  edx, edx
        jz    .vds_done
        inc   dword [.vds_ptr]

        mov  ebx, [.vds_x]
        mov  ecx, [.vds_y]
        mov  esi, [.vds_colour]
        mov  eax, [.vds_scale]
        call vbe_draw_char

        ; advance x by (FONT_W + 1) * scale
        mov  eax, [.vds_scale]
        imul eax, FONT_W + 1
        add  [.vds_x], eax
        jmp  .vds_loop

.vds_done:
        popad
        ret

.vds_ptr:    dd 0
.vds_scale:  dd 1
.vds_colour: dd 0xFFFFFF
.vds_x:      dd 0
.vds_y:      dd 0

;-----------------------------------------------------------------------
; vbe_draw_num - Draw a uint32 in decimal
; Input:  EBX=x, ECX=y, EDX=value, ESI=colour, EAX=scale
;-----------------------------------------------------------------------
vbe_draw_num:
        pushad
        mov [.vdn_scale],  eax
        mov [.vdn_colour], esi
        mov [.vdn_x],      ebx
        mov [.vdn_y],      ecx

        ; convert to decimal string
        mov  eax, edx
        test eax, eax
        jnz  .vdn_nonzero
        mov  byte [.vdn_buf],     '0'
        mov  byte [.vdn_buf + 1], 0
        mov  edx, .vdn_buf
        jmp  .vdn_draw

.vdn_nonzero:
        mov  esi, .vdn_buf + 10
        mov  byte [esi], 0
        dec  esi
.vdn_digit:
        test eax, eax
        jz   .vdn_digit_done
        xor  edx, edx
        mov  ecx, 10
        div  ecx
        add  dl, '0'
        mov  [esi], dl
        dec  esi
        jmp  .vdn_digit
.vdn_digit_done:
        inc  esi                    ; ESI = first char
        mov  edx, esi

.vdn_draw:
        mov  ebx, [.vdn_x]
        mov  ecx, [.vdn_y]
        mov  esi, [.vdn_colour]
        mov  eax, [.vdn_scale]
        call vbe_draw_str

        popad
        ret

.vdn_scale:  dd 1
.vdn_colour: dd 0xFFFFFF
.vdn_x:      dd 0
.vdn_y:      dd 0
.vdn_buf:    times 12 db 0

;-----------------------------------------------------------------------
; vbe_fill_circle - Draw a filled disc (concentric circles)
; Input:  EBX=cx, ECX=cy, EDX=r, ESI=colour
;-----------------------------------------------------------------------
vbe_fill_circle:
        pushad
        mov [.vfc_cx], ebx
        mov [.vfc_cy], ecx
        mov [.vfc_r],  edx
        mov [.vfc_col], esi
.vfc_loop:
        cmp dword [.vfc_r], 0
        jl  .vfc_done
        mov  ebx, [.vfc_cx]
        mov  ecx, [.vfc_cy]
        mov  edx, [.vfc_r]
        mov  esi, [.vfc_col]
        call vbe_draw_circle
        dec  dword [.vfc_r]
        jmp  .vfc_loop
.vfc_done:
        popad
        ret

.vfc_cx:  dd 0
.vfc_cy:  dd 0
.vfc_r:   dd 0
.vfc_col: dd 0

;=======================================================================
; FONT DATA  (5x7, 7 bytes/glyph, first char = 0x20 ' ')
;=======================================================================
font_data:

; 0x20 ' '
        db 0x00,0x00,0x00,0x00,0x00,0x00,0x00
; 0x21 '!'
        db 0x04,0x04,0x04,0x04,0x04,0x00,0x04
; 0x22 '"'
        db 0x0A,0x0A,0x00,0x00,0x00,0x00,0x00
; 0x23 '#'
        db 0x0A,0x1F,0x0A,0x0A,0x1F,0x0A,0x00
; 0x24 '$'
        db 0x04,0x0F,0x14,0x0E,0x05,0x1E,0x04
; 0x25 '%'
        db 0x18,0x19,0x02,0x04,0x08,0x13,0x03
; 0x26 '&'
        db 0x0C,0x12,0x14,0x08,0x15,0x12,0x0D
; 0x27 '\''
        db 0x06,0x04,0x08,0x00,0x00,0x00,0x00
; 0x28 '('
        db 0x02,0x04,0x08,0x08,0x08,0x04,0x02
; 0x29 ')'
        db 0x08,0x04,0x02,0x02,0x02,0x04,0x08
; 0x2A '*'
        db 0x00,0x04,0x15,0x0E,0x15,0x04,0x00
; 0x2B '+'
        db 0x00,0x04,0x04,0x1F,0x04,0x04,0x00
; 0x2C ','
        db 0x00,0x00,0x00,0x00,0x06,0x04,0x08
; 0x2D '-'
        db 0x00,0x00,0x00,0x1F,0x00,0x00,0x00
; 0x2E '.'
        db 0x00,0x00,0x00,0x00,0x00,0x06,0x06
; 0x2F '/'
        db 0x01,0x01,0x02,0x04,0x08,0x10,0x10
; 0x30 '0'
        db 0x0E,0x11,0x13,0x15,0x19,0x11,0x0E
; 0x31 '1'
        db 0x04,0x0C,0x04,0x04,0x04,0x04,0x0E
; 0x32 '2'
        db 0x0E,0x11,0x01,0x02,0x04,0x08,0x1F
; 0x33 '3'
        db 0x1F,0x02,0x04,0x02,0x01,0x11,0x0E
; 0x34 '4'
        db 0x02,0x06,0x0A,0x12,0x1F,0x02,0x02
; 0x35 '5'
        db 0x1F,0x10,0x1E,0x01,0x01,0x11,0x0E
; 0x36 '6'
        db 0x06,0x08,0x10,0x1E,0x11,0x11,0x0E
; 0x37 '7'
        db 0x1F,0x01,0x02,0x04,0x08,0x08,0x08
; 0x38 '8'
        db 0x0E,0x11,0x11,0x0E,0x11,0x11,0x0E
; 0x39 '9'
        db 0x0E,0x11,0x11,0x0F,0x01,0x02,0x0C
; 0x3A ':'
        db 0x00,0x06,0x06,0x00,0x06,0x06,0x00
; 0x3B ';'
        db 0x00,0x06,0x06,0x00,0x06,0x04,0x08
; 0x3C '<'
        db 0x02,0x04,0x08,0x10,0x08,0x04,0x02
; 0x3D '='
        db 0x00,0x00,0x1F,0x00,0x1F,0x00,0x00
; 0x3E '>'
        db 0x08,0x04,0x02,0x01,0x02,0x04,0x08
; 0x3F '?'
        db 0x0E,0x11,0x01,0x02,0x04,0x00,0x04
; 0x40 '@'
        db 0x0E,0x11,0x01,0x0D,0x15,0x15,0x0E
; 0x41 'A'
        db 0x04,0x0A,0x11,0x11,0x1F,0x11,0x11
; 0x42 'B'
        db 0x1E,0x11,0x11,0x1E,0x11,0x11,0x1E
; 0x43 'C'
        db 0x0E,0x11,0x10,0x10,0x10,0x11,0x0E
; 0x44 'D'
        db 0x1C,0x12,0x11,0x11,0x11,0x12,0x1C
; 0x45 'E'
        db 0x1F,0x10,0x10,0x1E,0x10,0x10,0x1F
; 0x46 'F'
        db 0x1F,0x10,0x10,0x1E,0x10,0x10,0x10
; 0x47 'G'
        db 0x0E,0x11,0x10,0x17,0x11,0x11,0x0F
; 0x48 'H'
        db 0x11,0x11,0x11,0x1F,0x11,0x11,0x11
; 0x49 'I'
        db 0x0E,0x04,0x04,0x04,0x04,0x04,0x0E
; 0x4A 'J'
        db 0x07,0x02,0x02,0x02,0x02,0x12,0x0C
; 0x4B 'K'
        db 0x11,0x12,0x14,0x18,0x14,0x12,0x11
; 0x4C 'L'
        db 0x10,0x10,0x10,0x10,0x10,0x10,0x1F
; 0x4D 'M'
        db 0x11,0x1B,0x15,0x11,0x11,0x11,0x11
; 0x4E 'N'
        db 0x11,0x19,0x15,0x13,0x11,0x11,0x11
; 0x4F 'O'
        db 0x0E,0x11,0x11,0x11,0x11,0x11,0x0E
; 0x50 'P'
        db 0x1E,0x11,0x11,0x1E,0x10,0x10,0x10
; 0x51 'Q'
        db 0x0E,0x11,0x11,0x11,0x15,0x12,0x0D
; 0x52 'R'
        db 0x1E,0x11,0x11,0x1E,0x14,0x12,0x11
; 0x53 'S'
        db 0x0F,0x10,0x10,0x0E,0x01,0x01,0x1E
; 0x54 'T'
        db 0x1F,0x04,0x04,0x04,0x04,0x04,0x04
; 0x55 'U'
        db 0x11,0x11,0x11,0x11,0x11,0x11,0x0E
; 0x56 'V'
        db 0x11,0x11,0x11,0x11,0x11,0x0A,0x04
; 0x57 'W'
        db 0x11,0x11,0x11,0x15,0x15,0x1B,0x11
; 0x58 'X'
        db 0x11,0x11,0x0A,0x04,0x0A,0x11,0x11
; 0x59 'Y'
        db 0x11,0x11,0x0A,0x04,0x04,0x04,0x04
; 0x5A 'Z'
        db 0x1F,0x01,0x02,0x04,0x08,0x10,0x1F
; 0x5B '['
        db 0x0E,0x08,0x08,0x08,0x08,0x08,0x0E
; 0x5C '\'
        db 0x10,0x10,0x08,0x04,0x02,0x01,0x01
; 0x5D ']'
        db 0x0E,0x02,0x02,0x02,0x02,0x02,0x0E
; 0x5E '^'
        db 0x04,0x0A,0x11,0x00,0x00,0x00,0x00
; 0x5F '_'
        db 0x00,0x00,0x00,0x00,0x00,0x00,0x1F

%endif ; FONT_INC
